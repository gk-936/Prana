# Optional weather fallback
OPENWEATHER_API_KEY=

# Optional air-quality station reference/fallback
OPENAQ_API_KEY=

# WhatsApp Business Cloud API / provider
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BOT_NUMBER=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# LLM provider for WhatsApp bot language understanding/generation
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=

# Local fallback LLM through Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=

# App/backend runtime
APP_ENV=development
DATABASE_URL=sqlite:///./prana.db
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
